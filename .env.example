# Eventify environment sample

# --- Database Configuration ---
MONGODB_URI=mongodb://localhost:27017/eventify

# --- NextAuth Configuration ---
NEXTAUTH_SECRET=change-me-to-a-strong-random-string
NEXTAUTH_URL=http://localhost:3000

# If you want to flag users using the default password, set the plain default password.
# The code compares this against the stored bcrypt hash. OPTIONAL
DEFAULT_PASSWORD=Welcome@321

# --- Email (SMTP) Configuration ---
# OPTIONAL: required for password reset emails
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-email-password

# --- AWS S3 Configuration (Optional) ---
# OPTIONAL: required for file upload/delete features
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET_NAME=your-bucket-name

# --- Application Configuration ---
IS_DEV=true
NEXT_PUBLIC_URL=http://localhost:3000

# --- Security Configuration ---
# Bcrypt hash for the default password (matches DEFAULT_PASSWORD above by default)
# Generate a new hash if you change DEFAULT_PASSWORD.
DEFAULT_PASSWORD_HASH=$2a$10$OTAVa.umH/vANyQ53DCpCOM9XrKAguEatocXzWSUQiXFSEIyTYcqG